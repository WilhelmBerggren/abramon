TYPE=healthcheck

# A friendly name for this node; used in alert subject lines and bodies.
LABEL=my-vps

# swarm-cronjob schedule (standard 5-field cron). Default: every 5 minutes.
CRON_SCHEDULE='*/5 * * * *'

#=== Email (Postal HTTP API) =========================================
# Comma-separated list of recipients.
ALERT_TO=ops@example.com
# Must be an address on a domain your Postal server (or its org) owns.
ALERT_FROM=alerts@example.com
# Base URL of your Postal install, no trailing slash.
POSTAL_URL=https://postal.example.com

#=== Thresholds ======================================================
DISK_PCT=85
INODE_PCT=85
MEM_PCT=90
SWAP_PCT=80
LOAD_PER_CORE=2.0
COOLDOWN_HOURS=6
# Space-separated host mount points to watch (paths as seen on the host).
MOUNTS=/ /var/lib/docker

#=== Docker API ======================================================
# Points at the bundled socket-proxy service.
DOCKER_HOST=tcp://socket-proxy:2375

#=== Versions (bump when the file/secret content changes) ============
HEALTHCHECK_VERSION=v1
SECRET_POSTAL_API_KEY_VERSION=v1

COMPOSE_FILE=compose.yml
